{
    "editor.fontFamily": "FantasqueSansM Nerd Font, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 20,
    "terminal.integrated.fontSize": 18,
    "editor.fontLigatures": true,
    "editor.tabSize": 2,
    "editor.lineHeight": 1.1,
    "editor.rulers": [
      80
    ],
    "editor.renderWhitespace": "all",
    "editor.renderLineHighlight": "gutter",
    "telemetry.telemetryLevel": "off",
    "diffEditor.ignoreTrimWhitespace": false,
    "r.workspaceViewer.removeHiddenItems": true,
    "r.session.data.pageSize": 100,
    "todo-tree.regex.regex": "(//|#|--|<!--|;|/\\*|^|^[ \\t]*(-|\\d+.))\\s*($TAGS)",
    "todo-tree.tree.expanded": true,
    "todo-tree.general.tags": [
      "BUG",
      "HACK",
      "FIXME",
      "TODO",
      "XXX",
      "[ ]",
      "[x]",
      "NOTE",
      "TEMP",
      "COMBAK",
      "BUG"
    ],
    "editor.minimap.size": "fit",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.colorTheme": "One Dark Pro Darker",
    "workbench.preferredDarkColorTheme": "One Dark Pro Darker",
    "r.plot.devArgs": {
      "height": 500
    },
    "r.removeLeadingComments": true,
    "r.source.echo": true,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "errorLens.fontSize": "15",
    "errorLens.fontWeight": "300",
    "errorLens.gutterIconsEnabled": true,
    "errorLens.enabledInMergeConflict": false,
    "errorLens.followCursor": "closestProblem",
    "errorLens.followCursorMore": 5,
    "errorLens.fontStyleItalic": true,
    "errorLens.gutterIconSet": "borderless",
    "errorLens.gutterIconSize": "contain",
    "workbench.iconTheme": "symbols",
    "symbols.hidesExplorerArrows": true,
    "r.plot.useHttpgd": true,
    "r.lsp.debug": true,
    "r.rpath.mac": "/usr/local/bin/R",
    "[r]": {
      "editor.defaultFormatter": "REditorSupport.r",
      "editor.wordSeparators": "`~!@#%$^&*()-=+[{]}\\|;:'\",<>/?",
      "files.trimTrailingWhitespace": true,
      "files.insertFinalNewline": true
    },
    "window.commandCenter": false,
    "workbench.tree.enableStickyScroll": true,
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.defaultModel": "foldingProviderModel",
    "workbench.sideBar.location": "right",
    "workbench.editor.enablePreview": false,
    "r.bracketedPaste": true,
    "r.sessionWatcher": true,
    "r.lsp.diagnostics": false
}
